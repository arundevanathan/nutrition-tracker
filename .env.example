# Cloudflare Worker
WORKER_PUBLIC_URL=https://your-worker.example.workers.dev

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key-in-worker-secrets

# OAuth proof of concept
OAUTH_ALLOWED_CLIENT_IDS=chatgpt-oauth-test
OAUTH_ALLOWED_REDIRECT_URIS=https://chat.openai.com/aip/g-REPLACE_ME/oauth/callback,https://chatgpt.com/aip/g-REPLACE_ME/oauth/callback
OAUTH_CODE_TTL_SECONDS=300
OAUTH_TOKEN_TTL_SECONDS=2592000
