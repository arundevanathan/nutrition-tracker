# Cloudflare Worker
WORKER_PUBLIC_URL=https://app.calorie-track.com
DASHBOARD_ALLOWED_ORIGIN=https://app.calorie-track.com

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key-in-worker-secrets

# Dashboard
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=replace-with-supabase-anon-key
VITE_WORKER_API_URL=/api

# OAuth proof of concept
OAUTH_CODE_TTL_SECONDS=300
OAUTH_TOKEN_TTL_SECONDS=2592000
